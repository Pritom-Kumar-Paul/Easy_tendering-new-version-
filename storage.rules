rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Admin side: tender docs (we keep read public for convenience)
    match /tenders/{tenderId}/docs/{fileName} {
      allow read: if true;
      // Dev: any signed-in can upload; in prod use custom claims to restrict to admin
      allow write: if request.auth != null;
    }

    // Bidder side: attachments and signature
    match /bids/{tenderId}/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // KYC uploads
    match /kyc/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}